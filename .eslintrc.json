{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "indent": ["error", 4],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-empty": "warn",
    "no-multi-spaces": ["error", { "ignoreEOLComments": true }]
  },
  "overrides": [
    {
      "files": ["*.html"],
      "parser": "@html-eslint/parser",
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "script"
      },
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "off"
      }
    }
  ]
}